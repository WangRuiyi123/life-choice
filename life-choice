                    { emoji: '🦶', title: '踮脚练习', content: '踮脚尖站立30秒，重复3组', tag: '小腿训练' },
                    { emoji: '🫁', title: '深呼吸', content: '腹式呼吸5分钟，吸气4秒呼气6秒', tag: '呼吸训练' },
                    { emoji: '🚶', title: '散步时间', content: '出门散步15分钟，不看手机', tag: '轻度运动' },
                    { emoji: '🥗', title: '健康加餐', content: '吃点水果或坚果，拒绝垃圾食品', tag: '饮食健康' }
                ]
            }
        };

        let currentCategory = null;
        let loadingInterval = null;
        let isLoading = false;

        function goToCategory(category) {
            currentCategory = category;
            const data = blindboxData[category];
            
            document.getElementById('homePage').style.display = 'none';
            document.getElementById('blindboxPage').style.display = 'block';
            document.getElementById('windowTitle').textContent = data.title;
            document.getElementById('categoryTitle').textContent = data.title;
            
            resetBlindBox();
        }

        function goHome() {
            if (loadingInterval) {
                clearInterval(loadingInterval);
                loadingInterval = null;
            }
            isLoading = false;
            
            document.getElementById('homePage').style.display = 'block';
            document.getElementById('blindboxPage').style.display = 'none';
            document.getElementById('windowTitle').textContent = 'LifeChoice.exe';
            currentCategory = null;
        }

        function resetBlindBox() {
            if (loadingInterval) {
                clearInterval(loadingInterval);
                loadingInterval = null;
            }
            isLoading = false;
            
            const data = blindboxData[currentCategory];
            
            document.getElementById('blindboxDisplay').innerHTML = `
                <div class="blindbox-icon" id="blindboxIcon">${data.icon}</div>
                <div class="blindbox-text" id="blindboxText">Ready to open! (准备开启)</div>
            `;
            
            document.getElementById('progressFill').style.width = '0%';
            document.getElementById('progressText').textContent = 'Waiting...';
            document.getElementById('statusText').textContent = 'Click DRAW to start';
            
            document.getElementById('actionArea').innerHTML = `
                <button class="btn btn-primary" onclick="drawBlindBox()">
                    🎲 抽盲盒 (DRAW)
                </button>
            `;
        }

        function drawBlindBox() {
            if (isLoading) {
                return;
            }
            
            isLoading = true;
            
            if (loadingInterval) {
                clearInterval(loadingInterval);
                loadingInterval = null;
            }
            
            const data = blindboxData[currentCategory];
            document.getElementById('blindboxDisplay').innerHTML = `
                <div class="blindbox-icon" id="blindboxIcon">${data.icon}</div>
                <div class="blindbox-text" id="blindboxText">Opening... (开启中)</div>
            `;
            
            const progressFill = document.getElementById('progressFill');
            const progressText = document.getElementById('progressText');
            const statusText = document.getElementById('statusText');
            const blindboxIcon = document.getElementById('blindboxIcon');
            
            document.getElementById('actionArea').innerHTML = `
                <button class="btn" disabled>
                    🔄 开启中... (OPENING)
                </button>
            `;
            
            progressFill.style.width = '0%';
            let progress = 0;
            
            loadingInterval = setInterval(() => {
                progress += 10;
                
                if (progress > 100) {
                    progress = 100;
                }
                
                progressFill.style.width = progress + '%';
                progressText.textContent = `Loading... ${progress}%`;
                statusText.textContent = 'Opening blind box...';
                
                if (blindboxIcon) {
                    blindboxIcon.style.opacity = progress % 20 < 10 ? '1' : '0.5';
                }
                
                if (progress >= 100) {
                    clearInterval(loadingInterval);
                    loadingInterval = null;
                    isLoading = false;
                    showResult();
                }
            }, 100);
        }

        function showResult() {
            const data = blindboxData[currentCategory];
            const randomItem = data.items[Math.floor(Math.random() * data.items.length)];
            
            document.getElementById('blindboxDisplay').innerHTML = `
                <div class="result-card">
                    <div class="result-emoji">${randomItem.emoji}</div>
                    <div class="result-title">${randomItem.title}</div>
                    <div class="result-content">${randomItem.content}</div>
                    <span class="result-tag">${randomItem.tag}</span>
                </div>
            `;
            
            document.getElementById('progressText').textContent = 'Complete!';
            document.getElementById('statusText').textContent = 'Item received!';
            
            document.getElementById('actionArea').innerHTML = `
                <button class="btn btn-primary" onclick="drawBlindBox()">
                    🔄 再抽一次 (AGAIN)
                </button>
            `;
        }
    </script>
</body>
</html>
