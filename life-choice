    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎀 LifeChoice.exe</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            image-rendering: pixelated;
        }

        body {
            font-family: 'VT323', 'Courier New', monospace;
            background: #c0c0c0;
            background-image: 
                linear-gradient(45deg, #d4d4d4 25%, transparent 25%), 
                linear-gradient(-45deg, #d4d4d4 25%, transparent 25%), 
                linear-gradient(45deg, transparent 75%, #d4d4d4 75%), 
                linear-gradient(-45deg, transparent 75%, #d4d4d4 75%);
            background-size: 20px 20px;
            background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }

        .window {
            background: #c0c0c0;
            border: 3px solid;
            border-color: #ffffff #808080 #808080 #ffffff;
            box-shadow: 3px 3px 0 #000000;
            max-width: 500px;
            width: 100%;
        }

        .title-bar {
            background: linear-gradient(90deg, #000080 0%, #1084d0 100%);
            color: white;
            padding: 4px 6px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 18px;
            font-weight: bold;
        }

        .title-bar-text {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .title-bar-buttons {
            display: flex;
            gap: 4px;
        }

        .window-btn {
            width: 20px;
            height: 18px;
            background: #c0c0c0;
            border: 2px solid;
            border-color: #ffffff #000000 #000000 #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            color: #000;
        }

        .window-btn:active {
            border-color: #000000 #ffffff #ffffff #000000;
        }

        .window-content {
            padding: 15px;
            background: #c0c0c0;
        }

        .btn {
            background: #c0c0c0;
            border: 3px solid;
            border-color: #ffffff #000000 #000000 #ffffff;
            padding: 8px 20px;
            font-family: 'VT323', monospace;
            font-size: 18px;
            cursor: pointer;
            color: #000;
            text-align: center;
            display: inline-block;
        }

        .btn:active {
            border-color: #000000 #ffffff #ffffff #000000;
            padding: 9px 19px 7px 21px;
        }

        .btn-primary {
            background: #ff69b4;
            color: white;
            font-weight: bold;
        }

        .btn-primary:active {
            background: #ff1493;
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .input-box {
            background: #ffffff;
            border: 3px solid;
            border-color: #808080 #ffffff #ffffff #808080;
            padding: 8px;
            font-family: 'VT323', monospace;
            font-size: 18px;
            width: 100%;
            outline: none;
        }

        .group-box {
            border: 3px solid;
            border-color: #808080 #ffffff #ffffff #808080;
            padding: 15px;
            margin-bottom: 15px;
            position: relative;
        }

        .group-box-title {
            position: absolute;
            top: -12px;
            left: 10px;
            background: #c0c0c0;
            padding: 0 8px;
            font-size: 16px;
            font-weight: bold;
        }

        .home-page {
            display: block;
        }

        .header-text {
            text-align: center;
            margin-bottom: 20px;
            font-size: 22px;
        }

        .category-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .category-item {
            background: #c0c0c0;
            border: 3px solid;
            border-color: #ffffff #000000 #000000 #ffffff;
            padding: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.1s;
        }

        .category-item:hover {
            background: #d4d4d4;
        }

        .category-item:active {
            border-color: #000000 #ffffff #ffffff #000000;
        }

        .category-icon {
            font-size: 32px;
            width: 50px;
            text-align: center;
        }

        .category-info {
            flex: 1;
        }

        .category-name {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 2px;
        }

        .category-desc {
            font-size: 14px;
            color: #555;
        }

        .blindbox-page {
            display: none;
        }

        .blindbox-display {
            background: #000000;
            border: 3px solid;
            border-color: #808080 #ffffff #ffffff #808080;
            padding: 40px;
            text-align: center;
            margin-bottom: 20px;
            min-height: 250px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .blindbox-icon {
            font-size: 80px;
            margin-bottom: 20px;
            animation: blink 1s step-end infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .blindbox-text {
            color: #00ff00;
            font-size: 20px;
            text-shadow: 0 0 10px #00ff00;
        }

        .action-area {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .result-card {
            background: #ffffff;
            border: 3px solid;
            border-color: #000000 #ffffff #ffffff #000000;
            padding: 20px;
            text-align: center;
            animation: popIn 0.3s ease;
        }

        @keyframes popIn {
            0% { transform: scale(0.8); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        .result-emoji {
            font-size: 60px;
            margin-bottom: 15px;
        }

        .result-title {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 10px;
            color: #000080;
        }

        .result-content {
            font-size: 20px;
            margin-bottom: 15px;
            line-height: 1.4;
        }

        .result-tag {
            display: inline-block;
            background: #000080;
            color: white;
            padding: 4px 12px;
            font-size: 16px;
        }

        .progress-bar {
            background: #808080;
            border: 2px solid;
            border-color: #000000 #ffffff #ffffff #000000;
            height: 25px;
            margin-bottom: 15px;
            position: relative;
        }

        .progress-fill {
            background: linear-gradient(90deg, #ff69b4 0%, #ff1493 100%);
            height: 100%;
            width: 0%;
            transition: width 0.5s;
        }

        .progress-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 16px;
            font-weight: bold;
            text-shadow: 1px 1px 0 #000;
        }

        .bottom-buttons {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .bottom-buttons .btn {
            flex: 1;
        }

        .status-bar {
            background: #c0c0c0;
            border-top: 2px solid #ffffff;
            padding: 4px 8px;
            font-size: 14px;
            display: flex;
            justify-content: space-between;
            margin-top: 15px;
        }

        .pixel-decoration {
            position: fixed;
            font-size: 24px;
            opacity: 0.3;
            pointer-events: none;
        }

        @media (max-width: 520px) {
            body {
                padding: 10px;
            }
            
            .window {
                max-width: 100%;
            }
        }
    </style>
</head>
